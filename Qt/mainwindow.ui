  <property name="styleSheet">
   <string notr="true">QMainWindow {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #EEF5FF, stop:0.5 #F0F8FF, stop:1 #E8F4FF);
}

/* ------------------------------
   左侧面板 - 深蓝色
------------------------------ */
QFrame#leftPanel {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #1E3A5F, stop:0.5 #1A3050, stop:1 #162845);
    border-radius: 0;
}

/* ------------------------------
   毛玻璃卡片样式
------------------------------ */
QFrame#cardSystem, 
QFrame#cardTime, 
QFrame#cardConnection,
QFrame#cardFan, 
QFrame#cardHeat, 
QFrame#cardThreshold {
    background-color: rgba(255, 255, 255, 0.75);
    border-radius: 16px;
    border: 1px solid rgba(200, 220, 255, 0.5);
}

QFrame#tempCard, 
QFrame#humiCard {
    background-color: rgba(255, 255, 255, 0.75);
    border-radius: 16px;
    border: 1px solid rgba(200, 220, 255, 0.5);
}

/* 卡片悬浮效果 */
QFrame#cardSystem:hover, 
QFrame#cardTime:hover, 
QFrame#cardConnection:hover,
QFrame#cardFan:hover, 
QFrame#cardHeat:hover, 
QFrame#cardThreshold:hover,
QFrame#tempCard:hover, 
QFrame#humiCard:hover {
    background-color: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(100, 150, 220, 0.6);
}

/* ------------------------------
   CheckBox 开关
------------------------------ */
QCheckBox {
    spacing: 0;
}
QCheckBox::indicator {
    width: 52px;
    height: 26px;
}
QCheckBox::indicator:unchecked {
    image: url(:/images/off.svg);
}
QCheckBox::indicator:checked {
    image: url(:/images/on.svg);
}

/* ------------------------------
   按钮美化 - 统一蓝色系
------------------------------ */
QPushButton {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #4A90D9, stop:1 #357ABD);
    color: white;
    border-radius: 8px;
    padding: 6px 16px;
    font-weight: 600;
    border: none;
}

QPushButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #5BA0E9, stop:1 #4A90D9);
}

QPushButton:pressed {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #357ABD, stop:1 #2868A8);
}

QPushButton:disabled {
    background-color: #C5D5E8;
    color: #8BA4C0;
}

/* 导航按钮样式 */
QPushButton#btnNavHome,
QPushButton#btnNavControl,
QPushButton#btnNavLogs,
QPushButton#btnNavTempHumi {
    background-color: transparent;
    color: #A8C8E8;
    border-radius: 8px;
    padding: 10px 16px;
    font-weight: 500;
    border: none;
    text-align: left;
}

QPushButton#btnNavHome:hover,
QPushButton#btnNavControl:hover,
QPushButton#btnNavLogs:hover,
QPushButton#btnNavTempHumi:hover {
    background-color: rgba(255, 255, 255, 0.15);
    color: #FFFFFF;
}

QPushButton#btnNavHome:pressed,
QPushButton#btnNavControl:pressed,
QPushButton#btnNavLogs:pressed,
QPushButton#btnNavTempHumi:pressed {
    background-color: rgba(255, 255, 255, 0.25);
}

/* ------------------------------
   模式按钮样式 - 统一蓝色系
------------------------------ */
QPushButton#btnComfortMode {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #4A90D9, stop:1 #357ABD);
    color: white;
}
QPushButton#btnComfortMode:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #5BA0E9, stop:1 #4A90D9);
}

QPushButton#btnSleepMode {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #4A90D9, stop:1 #357ABD);
    color: white;
}
QPushButton#btnSleepMode:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #5BA0E9, stop:1 #4A90D9);
}

QPushButton#btnCinemaMode {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #4A90D9, stop:1 #357ABD);
    color: white;
}
QPushButton#btnCinemaMode:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #5BA0E9, stop:1 #4A90D9);
}

QPushButton#btnManualMode {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #4A90D9, stop:1 #357ABD);
    color: white;
}
QPushButton#btnManualMode:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #5BA0E9, stop:1 #4A90D9);
}

/* ------------------------------
   标签文字美化 - 蓝色系
------------------------------ */
QLabel {
    color: #1A3050;
}

QLabel#labelTitle {
    font-size: 14px;
    color: #4A6080;
}

QLabel#labelValue {
    font-size: 24px;
    font-weight: bold;
    color: #1E3A5F;
}

QLabel#lblLogo_2 {
    color: #E8F4FF;
}

QLabel#lblTimeDisplay {
    color: #A8C8E8;
}

QLabel#lblStatusLed {
    font-weight: bold;
}

QLabel#label_2 {
    color: #FFFFFF;
    font-weight: 500;
}

/* ------------------------------
   表格美化 - 蓝色系
------------------------------ */
QTableWidget {
    background-color: rgba(255, 255, 255, 0.8);
    border-radius: 8px;
    border: 1px solid rgba(200, 220, 255, 0.5);
}

QTableWidget::item {
    padding: 6px;
    border-bottom: 1px solid rgba(200, 220, 255, 0.3);
}

QTableWidget::item:hover {
    background-color: rgba(74, 144, 217, 0.15);
}

QTableWidget::item:selected {
    background-color: rgba(74, 144, 217, 0.25);
    color: #1E3A5F;
}

QTableWidget::horizontalHeader {
    background-color: rgba(232, 244, 255, 0.9);
    border-radius: 8px;
}

QTableWidget::horizontalHeader::section {
    background-color: rgba(232, 244, 255, 0.9);
    color: #1A3050;
    padding: 8px;
    font-weight: 600;
    border: none;
    border-right: 1px solid rgba(200, 220, 255, 0.4);
}

QTableWidget::horizontalHeader::section:last-child {
    border-right: none;
}

QTableWidget::verticalHeader {
    background-color: rgba(232, 244, 255, 0.6);
}

QTableWidget::verticalHeader::section {
    background-color: rgba(232, 244, 255, 0.6);
    color: #4A6080;
    padding: 6px;
    border: none;
    border-bottom: 1px solid rgba(200, 220, 255, 0.3);
}

/* ------------------------------
   下拉框美化
------------------------------ */
QComboBox {
    background-color: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(200, 220, 255, 0.5);
    border-radius: 8px;
    padding: 6px 12px;
    color: #1A3050;
}

QComboBox:hover {
    border-color: #4A90D9;
}

QComboBox::drop-down {
    border: none;
}

QComboBox::down-arrow {
    image: url(:/images/arrow-down.svg);
    width: 16px;
    height: 16px;
}

/* ------------------------------
   状态栏
------------------------------ */
QStatusBar {
    background-color: rgba(232, 244, 255, 0.7);
    border-top: 1px solid rgba(200, 220, 255, 0.3);
    color: #1A3050;
}

/* ------------------------------
   滚动条美化 - 蓝色系
------------------------------ */
QScrollBar:vertical {
    background-color: rgba(200, 220, 255, 0.2);
    width: 8px;
    border-radius: 4px;
}

QScrollBar::handle:vertical {
    background-color: rgba(74, 144, 217, 0.4);
    border-radius: 4px;
}

QScrollBar::handle:vertical:hover {
    background-color: rgba(74, 144, 217, 0.6);
}

QScrollBar:horizontal {
    background-color: rgba(200, 220, 255, 0.2);
    height: 8px;
    border-radius: 4px;
}

QScrollBar::handle:horizontal {
    background-color: rgba(74, 144, 217, 0.4);
    border-radius: 4px;
}

QScrollBar::handle:horizontal:hover {
    background-color: rgba(74, 144, 217, 0.6);
}

/* ------------------------------
   仪表盘文字
------------------------------ */
QLabel#gaugeLabelTemp,
QLabel#gaugeLabelHumi {
    font-size: 12px;
    color: #4A6080;
}

QLabel#gaugeValueTemp,
QLabel#gaugeValueHumi {
    font-size: 20px;
    font-weight: bold;
    color: #1E3A5F;
}</string>
