  <property name="styleSheet">
   <string notr="true">QMainWindow {
    background-color: #F4F7FC;
}

/* ------------------------------
   卡片样式（去掉box-shadow，改用边框+背景区分）
------------------------------ */
QFrame#cardSystem, 
QFrame#cardTime, 
QFrame#cardConnection,
QFrame#cardFan, 
QFrame#cardHeat, 
QFrame#cardThreshold {
    background-color: #FFFFFF;
    border-radius: 14px;
    border: 1px solid #E6EBF2;
}

QFrame#tempCard, 
QFrame#humiCard {
    background-color: #FFFFFF;
    border-radius: 16px;
    border: 1px solid #E6EBF2;
}

/* 卡片悬浮效果：边框变蓝 + 背景轻微变亮 */
QFrame#cardSystem:hover, 
QFrame#cardTime:hover, 
QFrame#cardConnection:hover,
QFrame#cardFan:hover, 
QFrame#cardHeat:hover, 
QFrame#cardThreshold:hover,
QFrame#tempCard:hover, 
QFrame#humiCard:hover {
    background-color: #F8FBFF;
    border: 1px solid #4FACFE;
}

/* ------------------------------
   你的 CheckBox 开关 —— 完全不动！
------------------------------ */
QCheckBox {
    spacing: 0;
}
QCheckBox::indicator {
    width: 52px;
    height: 26px;
}
QCheckBox::indicator:unchecked {
    image: url(:/images/off.svg);
}
QCheckBox::indicator:checked {
    image: url(:/images/on.svg);
}

/* ------------------------------
   按钮美化：Qt 原生支持的效果
------------------------------ */
QPushButton {
    background-color: #4FACFE;
    color: white;
    border-radius: 6px;
    padding: 5px 12px;
    font-weight: bold;
    border: none;
}

QPushButton:hover {
    background-color: #00F2FE;
}

QPushButton:pressed {
    background-color: #3B9BEE;
}

/* ------------------------------
   标签文字美化
------------------------------ */
QLabel {
    color: #333333;
}

QLabel#labelTitle {
    font-size: 14px;
    color: #666666;
}

QLabel#labelValue {
    font-size: 24px;
    font-weight: bold;
    color: #222222;
}</string>
